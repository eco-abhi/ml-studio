# Copy to .env and adjust. All keys are optional unless noted.

# --- Optional API hardening ---
# If set, clients must send header: X-API-Key: <same value> (or Authorization: Bearer <same>)
# API_KEY=

# Comma-separated browser origins, or * (default). Tighten in production.
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set to false in production to hide internal exception text from JSON error bodies (errors still logged server-side).
# EXPOSE_ERROR_DETAILS=true

# --- MLflow (optional) ---
# Full override (file, sqlite, or http tracking server). If unset, see below.
# MLFLOW_TRACKING_URI=
#
# Local sqlite file (default: backend/mlruns.db next to main.py).
# MLflow UI: from this folder run `uv run python mlflow_ui_cli.py` (same store as the API).
# Or: mlflow ui --backend-store-uri "sqlite:////ABS/PATH/mlruns.db" --host 127.0.0.1 --port 5000
# Plain `mlflow ui` alone uses ./mlruns (file store) and will not see API runs; it may error on meta.yaml / "models" as runs.
# MLFLOW_SQLITE_PATH=
#
# Remote:
# DAGSHUB_MLFLOW_URI=
# DAGSHUB_TOKEN=

# --- Supabase storage (optional; omit for local data/uploads) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
